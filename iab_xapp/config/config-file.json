{
    "name": "iab-xapp",
    "version": "0.0.3",
    "containers": [
        {
            "name": "iab-xapp",
            "image": {
                "registry": "docker.io",
                "name": "dpugliese6/iab-xapp",
                "tag": "0.0.3"
            }
        }
    ],
    "messaging": {
        "ports": [
            {
                "name": "http",
                "container": "iab-xapp",
                "port": 8080,
                "description": "http service"
            },
            {
                "name": "rmrroute",
                "container": "iab-xapp",
                "port": 4561,
                "description": "rc route port"
            },
            {
                "name": "rmrdata",
                "container": "iab-xapp",
                "port": 4560,
                "rxMessages": ["RIC_SUB_RESP", "RIC_SUB_FAILURE", "RIC_SUB_DEL_RESP", "RIC_CONTROL_ACK", "RIC_CONTROL_FAILURE"],
                "txMessages": ["RIC_SUB_REQ", "RIC_SUB_DEL_REQ", "RIC_CONTROL_REQ"],
                "policies": [1],
                "description": "rmr data port for rc-xapp"
            }
        ]
    },
    "controls": {
        "subscription": {
          "url": "http://service-ricxapp-iab-xapp-http:8080/",
          "clientEndpoint": "service-ricxapp-iab-xapp-http"
        }
      }

}